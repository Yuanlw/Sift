# 数据库连接，供 Next.js 和后台处理使用。
# Database connection used by Next.js and background processing.
# 本地 Docker Postgres 保持默认值即可。
# For local Docker Postgres, keep this default.
DATABASE_URL=postgres://sift:sift@localhost:5432/sift

# 模型适配器类型；第一版使用 OpenAI-compatible API。
# Model adapter type. The first implementation uses OpenAI-compatible APIs.
MODEL_PROVIDER=openai-compatible

# 默认模型 API 地址；文本、embedding、视觉模型未单独配置时会复用它。
# Default model API base URL. Text, embedding, and vision settings fall back to this when their own base URL is empty.
MODEL_BASE_URL=http://127.0.0.1:9000/v1

# 默认模型 API Key；本地网关不需要真实密钥时可用 local。
# Default model API key. Use "local" for local gateways that do not require a real key.
MODEL_API_KEY=local

# 可选：Sift Model Gateway。配置后，默认模型会优先走 Sift 网关授权令牌，而不是本地/供应商 API Key。
# Optional: Sift Model Gateway. When configured, default models prefer the Sift gateway token over local/provider API keys.
# 两个变量必须成对填写；只填一个会被视为配置错误，避免 endpoint/key 混用。
# Both values must be set together; setting only one is a configuration error to avoid endpoint/key mixing.
SIFT_MODEL_GATEWAY_BASE_URL=
SIFT_MODEL_GATEWAY_API_KEY=

# 可选：Sift Cloud 控制面 API Key，用于模型网关调用 token 校验接口。
# Optional: Sift Cloud control-plane API key used by the model gateway to validate gateway tokens.
SIFT_CLOUD_CONTROL_API_KEY=

# 智能额度成本参数。它们把模型成本换算成内部额度，便于控制毛利。
# Smart quota cost parameters. They convert model cost into internal credits to protect gross margin.
SIFT_SMART_QUOTA_USD_PER_CREDIT=0.0001
SIFT_SMART_QUOTA_COST_MULTIPLIER=2
SIFT_COST_TEXT_INPUT_USD_PER_MILLION_TOKENS=0.029
SIFT_COST_TEXT_OUTPUT_USD_PER_MILLION_TOKENS=0.287
SIFT_COST_EMBEDDING_INPUT_USD_PER_MILLION_TOKENS=0.072
SIFT_COST_VISION_INPUT_USD_PER_MILLION_TOKENS=0.043
SIFT_COST_VISION_OUTPUT_USD_PER_MILLION_TOKENS=0.072
SIFT_COST_VISION_IMAGE_USD=0.002

# 可选：运营/客服后台管理员邮箱白名单，逗号分隔。未配置时 /admin/account-support 不开放。
# Optional: comma-separated admin email allowlist for support console. /admin/account-support is closed when empty.
SIFT_ADMIN_EMAILS=

# 文本/聊天模型名称，用于提取、总结、生成 Wiki 和回答 Ask。
# Text/chat model name used for extraction, summarization, wiki generation, and Ask answers.
MODEL_TEXT_MODEL=Qwen3.5-27B-Claude-4.6-Opus-Distilled-MLX-4bit

# 可选文本模型 API 地址；留空则复用 MODEL_BASE_URL。
# Optional text model base URL. Leave empty to reuse MODEL_BASE_URL.
MODEL_TEXT_BASE_URL=

# 可选文本模型 API Key；留空则复用 MODEL_API_KEY。
# Optional text model API key. Leave empty to reuse MODEL_API_KEY.
MODEL_TEXT_API_KEY=

# 可选思考模式开关；仅模型支持时填写 enabled 或 disabled。
# Optional thinking switch for text models that support it. Valid values: enabled, disabled.
MODEL_TEXT_THINKING=

# 可选推理强度；仅模型支持时填写 low、medium 或 high。
# Optional reasoning effort for text models that support it. Valid values: low, medium, high.
MODEL_TEXT_REASONING_EFFORT=

# Embedding 模型名称，用于生成检索向量。
# Embedding model name used to create vector chunks for retrieval.
MODEL_EMBEDDING_MODEL=bge-m3-mlx-fp16

# Embedding 向量维度，必须和 supabase/schema.sql 里的 pgvector 列维度一致。
# Embedding vector dimension. Must match the pgvector column dimension in supabase/schema.sql.
MODEL_EMBEDDING_DIMENSIONS=1024

# 可选 embedding 模型 API 地址；留空则复用 MODEL_BASE_URL。
# Optional embedding model base URL. Leave empty to reuse MODEL_BASE_URL.
MODEL_EMBEDDING_BASE_URL=

# 可选 embedding 模型 API Key；留空则复用 MODEL_API_KEY。
# Optional embedding model API key. Leave empty to reuse MODEL_API_KEY.
MODEL_EMBEDDING_API_KEY=

# 可选视觉模型 API 地址，用于图片 OCR；留空则复用文本/默认模型地址。
# Optional vision model base URL for image OCR. Leave empty to reuse the text/default model URL.
MODEL_VISION_BASE_URL=

# 可选视觉模型 API Key；留空则复用文本/默认模型 Key。
# Optional vision model API key for image OCR. Leave empty to reuse the text/default model key.
MODEL_VISION_API_KEY=

# 可选视觉模型名称；留空则复用 MODEL_TEXT_MODEL。
# Optional vision model name for image OCR. Leave empty to reuse MODEL_TEXT_MODEL.
MODEL_VISION_MODEL=

# 后台任务派发模式；本地建议 inline，inngest 用于外部任务系统，none 只入队不处理。
# Background job dispatch mode. inline is easiest locally; inngest is for external job dispatch; none only queues jobs.
JOB_DISPATCHER=inline

# Inngest event key；仅 JOB_DISPATCHER=inngest 时需要。
# Inngest event key. Required only when JOB_DISPATCHER=inngest.
INNGEST_EVENT_KEY=

# Inngest signing key；仅 JOB_DISPATCHER=inngest 时需要。
# Inngest signing key. Required only when JOB_DISPATCHER=inngest.
INNGEST_SIGNING_KEY=

# 本地/原型模式的默认单用户 ID，保持稳定 UUID 即可。
# Default single-user id for local/prototype mode. Keep as a stable UUID.
SIFT_SINGLE_USER_ID=00000000-0000-0000-0000-000000000001

# 是否要求登录后访问核心页面和用户 API；账号体系开启后建议保持 true。
# Whether core pages and user APIs require sign-in. Keep true after enabling accounts.
SIFT_REQUIRE_AUTH=true

# 登录 session 签名密钥，生产环境必须替换为至少 32 个字符的随机密钥。
# Secret used to sign login sessions. Replace in production with a random secret of at least 32 characters.
SIFT_SESSION_SECRET=local-development-sift-session-secret-change-me

# 是否信任上游代理传入的用户 ID；本地单用户模式保持 false。
# Whether to trust a user id from an upstream proxy/header. Keep false for local single-user mode.
SIFT_TRUST_USER_HEADER=false

# SIFT_TRUST_USER_HEADER=true 时读取用户 ID 的请求头名称。
# Header name used for the upstream user id when SIFT_TRUST_USER_HEADER=true.
SIFT_USER_ID_HEADER=x-sift-user-id

# 公开注册开关。默认只允许创建第一个账号，后续注册需要显式开启。
# Public signup switch. By default only the first account can be created.
SIFT_ALLOW_PUBLIC_SIGNUP=false

# 可选 Bearer Token，用于保护 /api/agent/* 和 /api/mcp；SIFT_REQUIRE_AUTH=true 时留空则需要登录 session。
# Optional Bearer token for /api/agent/* and /api/mcp. When SIFT_REQUIRE_AUTH=true, an empty value requires a signed-in session.
SIFT_AGENT_API_KEY=

# Agent API Key 绑定的用户 ID。多账号部署使用 Agent Key 时必须显式配置。
# User id bound to the Agent API key. Required for multi-account deployments that use an Agent key.
SIFT_AGENT_USER_ID=

# 自定义模型 API Key 的服务端加密密钥。SaaS/多人部署必须配置，至少 32 个字符；本地单用户可留空。
# Server-side encryption secret for user-provided custom model API keys. Required for SaaS/multi-user deployments; at least 32 chars. Optional for local single-user use.
SIFT_MODEL_KEY_ENCRYPTION_SECRET=

# SaaS 托管部署地址，用于 Stripe Checkout 成功/取消跳转。
# Hosted SaaS app URL, used for Stripe Checkout success/cancel redirects.
SIFT_APP_URL=http://localhost:3000

# 公开网站联系信息。提交 Stripe 审核前必须替换为真实、稳定、可保持一致的信息。
# Public website contact information. Replace with real, stable, consistent information before Stripe review.
SIFT_CONTACT_EMAIL=contact@example.com
SIFT_BUSINESS_NAME=Sift
SIFT_BUSINESS_ADDRESS=

# 公开价格页展示文案。提交支付审核前应填写真实价格，并与 Stripe Price 保持一致。
# Public pricing labels. Before payment review, use real prices consistent with Stripe Prices.
SIFT_PRICE_LABEL_PERSONAL=
SIFT_PRICE_LABEL_PRO=
SIFT_PRICE_LABEL_TEAM=

# Stripe 只在 SaaS/托管默认模型模式需要。本地单租户可留空。
# Stripe is only needed for SaaS/hosted default-model billing. Leave empty for local single-tenant use.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PERSONAL=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
